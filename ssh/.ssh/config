# ~/.ssh/config
# Managed by dotfiles — edit in ~/dotfiles/ssh/.ssh/config
# Private keys live in ~/.ssh/ and are NOT committed to the repo

## START GITPOD INTEGRATION
## This section is managed by Gitpod. Any manual changes will be lost.
Include "code_gitpod.d/config"
## END GITPOD INTEGRATION

Host github.com
    User git
    IdentityFile ~/.ssh/id_rsa
    IdentitiesOnly yes
    AddKeysToAgent yes
    UseKeychain yes

# Quartermaster GitHub account (pesveld@quartermaster.house)
# Use remote URLs like: git@github-qm:Quartermaster-Inc/<repo>.git
Host github-qm
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_qm
    IdentitiesOnly yes
    AddKeysToAgent yes
    UseKeychain yes
