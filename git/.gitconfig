# ~/.gitconfig
# Managed by dotfiles — edit in ~/dotfiles/git/.gitconfig

[user]
	name = Peter Esveld
	email = peter.esveld@gmail.com
	signingkey = E627597C59B12434

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	editor = code --wait

[pull]
	rebase = true

[init]
	defaultBranch = main

[commit]
	gpgsign = true

[gpg]
	program = gpg
